  <!-- Compile the protoc-generated sources -->
  <ItemGroup>
    <ClCompile Include="$(GeneratedDir)grSim_Commands.pb.cc" />
    <ClCompile Include="$(GeneratedDir)grSim_Packet.pb.cc" />
    <ClCompile Include="$(GeneratedDir)grSim_Replacement.pb.cc" />
    <ClCompile Include="$(GeneratedDir)grSim_Robotstatus.pb.cc" />
    <ClCompile Include="$(GeneratedDir)ssl_gc_common.pb.cc" />
    <ClCompile Include="$(GeneratedDir)ssl_simulation_config.pb.cc" />
    <ClCompile Include="$(GeneratedDir)ssl_simulation_control.pb.cc" />
    <ClCompile Include="$(GeneratedDir)ssl_simulation_error.pb.cc" />
    <ClCompile Include="$(GeneratedDir)ssl_simulation_robot_control.pb.cc" />
    <ClCompile Include="$(GeneratedDir)ssl_simulation_robot_feedback.pb.cc" />
