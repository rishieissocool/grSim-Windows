  <!-- ================================================================ -->
  <!--  Windows resource (icon)                                          -->
  <!-- ================================================================ -->
  <ItemGroup>
    <ResourceCompile Include="..\resources\grsim.rc" />
  </ItemGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />

  <!-- ================================================================ -->
  <!--  Post-build: copy runtime DLLs next to grSim.exe                 -->
  <!-- ================================================================ -->
  <Target Name="DeployRuntimeDlls" AfterTargets="Link">
    <PropertyGroup>
      <_DllSrc Condition="'$(Configuration)'=='Release'">$(VcpkgInstalled)\bin</_DllSrc>
      <_DllSrc Condition="'$(Configuration)'=='Debug'">$(VcpkgInstalled)\debug\bin</_DllSrc>
    </PropertyGroup>
    <ItemGroup>
      <_Dlls Include="$(_DllSrc)\*.dll" />
    </ItemGroup>
    <Copy SourceFiles="@(_Dlls)"
          DestinationFolder="$(OutDir)"
          SkipUnchangedFiles="true"
          Condition="Exists('$(_DllSrc)')" />
    <!-- Qt5 platform plugin (windows) is required at runtime -->
    <ItemGroup>
      <_QtPlatform Include="$(VcpkgInstalled)\plugins\platforms\qwindows*.dll" Condition="'$(Configuration)'=='Release'" />
      <_QtPlatform Include="$(VcpkgInstalled)\debug\plugins\platforms\qwindowsd*.dll" Condition="'$(Configuration)'=='Debug'" />
    </ItemGroup>
    <MakeDir Directories="$(OutDir)plugins\platforms" />
    <Copy SourceFiles="@(_QtPlatform)"
          DestinationFolder="$(OutDir)plugins\platforms"
          SkipUnchangedFiles="true" />
    <WriteLinesToFile
      File="$(OutDir)qt.conf"
      Lines="[Paths]&#x0D;&#x0A;Plugins = plugins"
      Overwrite="true" />
  </Target>

</Project>
