      <Message>protoc: %(Filename).proto</Message>
      <Command>if not exist "$(GeneratedDir)" mkdir "$(GeneratedDir)"
"$(ProtocExe)" --cpp_out="$(GeneratedDir)." --proto_path="%(RootDir)%(Directory)." "%(FullPath)"</Command>
